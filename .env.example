# Notion integration secret (from notion.so/my-integrations), used server-side
# by src/app/api/contact/route.ts to save contact form submissions.
NOTION_API_KEY=

# ID of the Notion database the integration should write to (share the
# database with the integration first).
NOTION_DATABASE_ID=

# ID of the "Warteliste — Reich Studio" Notion database used by
# src/app/api/waitlist/route.ts for the homepage/footer email signup.
# Share this database with the same integration as NOTION_API_KEY above,
# then paste its ID here (from the database URL, no dashes needed either way).
NOTION_WAITLIST_DATABASE_ID=

# Stripe Payment Link for the "AI-Fundament" digital product (create it at
# dashboard.stripe.com/payment-links after setting up a Stripe account, attach
# both PDFs from "digital prods/" as files to deliver on purchase, paste the
# full https://buy.stripe.com/... link here). Until this is set, the buy
# button on /produkte falls back to a "reserve by email" mailto link.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
